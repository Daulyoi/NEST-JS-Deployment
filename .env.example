NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=finsight_db
# Set DB_SSL=true to enable SSL (required for NeonDB/Render). Defaults to auto-enabling in production if not localhost.
DB_SSL=false
# Use DATABASE_URL to configure database connection via single connection string
# DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

JWT_SECRET=ganti-dengan-secret-yang-kuat-di-production
JWT_EXPIRES_IN=7d

# URL FastAPI yang bisa dijangkau dari NestJS
FASTAPI_URL=http://localhost:8000
FASTAPI_INTERNAL_KEY=dev-internal-key
